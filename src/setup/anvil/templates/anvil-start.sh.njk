#!/usr/bin/env sh

set -x

export PATH="$HOME/.foundry/bin:$PATH"

DATA_DIR={{ obj.dbDir }}
MNEMONIC={{ obj.mnemonic }}

# The value of balance in --balance flag is in ether and not wei.

anvil \
--port 9545 \
--balance 1000 \
--gas-limit 1000000000000 \
--gas-price 1 \
--accounts 10 \
--mnemonic $MNEMONIC
--code-size-limit 10000000000 \
--state $DATA_DIR \
--verbosity \
--block-time 1