#!/usr/bin/env sh

set -x

export PATH="$HOME/.foundry/bin:$PATH"

SERVER_PORT={{ obj.serverPort }}
DIR={{ obj.contracts.repositoryDir }}
ANVIL_PRIVATE_KEY={{ obj.defaultAnvilPrivateKey }}

{% for acc in obj.config.accounts %}
cast send {{ acc.address }} --value 1000ether --rpc-url http://localhost:$SERVER_PORT --private-key $ANVIL_PRIVATE_KEY
sleep 2
{% endfor %}

# Matic contracts repo
cd $DIR

# Loop over accounts and run the stake script for each
{% for acc in obj.config.accounts %}
forge script scripts/matic-cli-scripts/stake.s.sol:MaticStake --rpc-url http://localhost:$SERVER_PORT --private-key $ANVIL_PRIVATE_KEY --broadcast --sig "run(address,bytes,uint256,uint256)" {{ acc.address }} {{ acc.pub_key }} 10000000000000000000 10000000000000000000
sleep 2
{% endfor %}